# Server
PORT=3001

# If you want the WS to verify tokens with your Laravel API (recommended):
VERIFY_WITH_LARAVEL=true
API_BASE=http://127.0.0.1:8000/api   # Laravel base URL

# Redis (for heartbeat TTL + online set)
REDIS_URL=redis://127.0.0.1:6379

# Heartbeat TTL (ms)
HEARTBEAT_MS=30000

# App config fetch behavior
APP_CONFIG_CACHE_TTL_MS=60000
APP_CONFIG_POLL_MS=60000

# Snapshot mode: "count" or "list"
PRESENCE_SNAPSHOT_MODE=count
